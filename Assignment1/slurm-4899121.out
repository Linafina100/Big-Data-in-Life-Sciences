USER = lisa5634
JOB = 4899121
QOS = normal
#!/bin/bash -l

# --- SLURM PARAMETERS ---
#SBATCH -A uppmax2026-1-94
#SBATCH -p pelle
#SBATCH -n 1
#SBATCH -t 02:00:00
#SBATCH -J fly_ngs

# --- INSTRUCTOR REQUIRED LINES ---
echo USER = $USER
echo JOB = $SLURM_JOBID
echo QOS = $SLURM_JOB_QOS
cat $0

# --- MODULE SETUP ---
module load Bowtie2/2.5.4-GCC-13.3.0
module load SAMtools/1.22.1-GCC-13.3.0
module load bcftools/1.22.1-GCC-13.3.0

# --- MOVE TO SNIC_TMP ---
cd $SNIC_TMP

# --- COPY DATA TO SNIC_TMP ---
echo "Copying Fly data and references to SNIC_TMP..."
cp /proj/uppmax2026-1-94/ngs/fly/*.fq.gz .
cp /sw/data/igenomes/Drosophila_melanogaster/Ensembl/BDGP6/Sequence/WholeGenomeFasta/genome.fa* .

# Set the reference index path
REF="/sw/data/igenomes/Drosophila_melanogaster/Ensembl/BDGP6/Sequence/Bowtie2Index/genome"

echo "Starting the Bioinformatics Pipeline..."

# --- THE MASTER LOOP ---
for sample_file in *.fq.gz
do
    # Strip the .fq.gz off the file name
    base_name=$(basename $sample_file .fq.gz)
    
    echo "========================================"
    echo "Processing $base_name..."
    echo "========================================"

    # Step 3: Alignment
    bowtie2 -x $REF -U $sample_file -S ${base_name}.sam
    
    # Step 4: Sort
    samtools sort ${base_name}.sam -o ${base_name}.bam
    
    # Step 5: Index
    samtools index ${base_name}.bam
    
    # Step 7: Pile-up and Call
    bcftools mpileup -f genome.fa ${base_name}.bam | bcftools call -mv -Ob -o ${base_name}.bcf
    
    # Step 8: Convert to plain-text VCF
    bcftools view ${base_name}.bcf -o ${base_name}.vcf

done

echo "Pipeline complete! Rescuing final VCF files from SNIC_TMP..."

# --- RESCUE THE DATA ---
cp *.vcf ~/BigData/Assignment1/

echo "All done! Job finished successfully."
